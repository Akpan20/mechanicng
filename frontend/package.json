    "react-hot-toast": "^2.4.1",
    "react-leaflet": "^4.2.1",
    "react-player": "^3.4.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.21.3",
    "recharts": "^2.10.4",
    "redux-persist": "^6.0.0",
